#ifndef PAULI_H
#define PAULI_H

/*
 * =====================================================================================================================
 *                                                      includes
 * =====================================================================================================================
 */
#ifndef GATELIB_H
#include "gatelib.h"
#endif

@INCLUDE_LINALG@@INCLUDE_OMP@@INCLUDE_VECLIB@

/*
 * =====================================================================================================================
 *                                                      C++ check
 * =====================================================================================================================
 */

#ifdef __cplusplus
extern "C" {
#endif

/*
* =====================================================================================================================
*                                                  type definitions
* =====================================================================================================================
*/
typedef struct pauliOp {
    pauli_t* comps;
    cplx_t* coeffs;
    complength_t length;
    qubit_t qubits;
} pauliOp_t;

typedef struct pauliObs {
    pauli_t* comps;
    double* coeffs;
    complength_t length;
    qubit_t qubits;
} pauliObs_t;
@TYPEDEF_PROFILE@
/*
 * =====================================================================================================================
 *                                                  Apply Pauli string
 * =====================================================================================================================
 */
void applyPauliStr(state_t* state, const pauli_t paulistr[]);
@PAULI_STR_PROFILE@

/*
 * =====================================================================================================================
 *                                                  Apply Pauli operator
 * =====================================================================================================================
 */
void applyOpPauli(state_t* state, const pauliOp_t* op);
@PAULI_OP_PROFILE@

/*
 * =====================================================================================================================
 *                                                  Apply Pauli observable
 * =====================================================================================================================
 */
void applyObsPauli(state_t* state, const pauliObs_t* obs);
@PAULI_OBS_PROFILE@

/*
 * =====================================================================================================================
 *                                              Evolve with Pauli string
 * =====================================================================================================================
 */
void evolvePauliStr(state_t* state, const pauli_t paulistr[], double angle);
@PAULI_EVO_PROFILE@

/*
 * =====================================================================================================================
 *                                              Evolve with Pauli observable
 * =====================================================================================================================
 */
void evolveObsPauliTrotter(state_t* state, const pauliObs_t* obs, double angle);

void evolveObsPauliTrotterDagger(state_t* state, const pauliObs_t* obs, double angle);

#ifdef __cplusplus
extern "C" {
#endif

#endif /* PAULI_H */